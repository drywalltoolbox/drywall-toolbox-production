# ─── IMPORTANT: Environment-Specific Configuration ────────────────────────────
# This is a TEMPLATE ONLY — never edit this file for local development.
#
# For LOCAL DEV: Create frontend/.env.development (in .gitignore, never commit)
# For PRODUCTION: GitHub Actions uses GitHub Secrets (never reads .env files)
#
# Structure:
#   frontend/.env.example       ← Template (committed, no real secrets)
#   frontend/.env.development   ← Local dev config (NOT committed, .gitignore)
#   → GitHub Actions injects secrets at build time; .env.production is never used
#
# The webpack config automatically detects NODE_ENV and loads the right file.
#
# Architecture note: The React SPA never talks to WooCommerce directly.
# All WC API calls go through the server-side proxy (drywall/v1 REST namespace)
# in wp-content/mu-plugins/dtb-rest-api.php. WC credentials are SERVER-ONLY
# constants defined in wp-config.php (see wp/.env.example for that template).
# ──────────────────────────────────────────────────────────────────────────────

# ─── WordPress Site URL ────────────────────────────────────────────────────────
# Root domain where WordPress and the headless proxy are hosted.
# Consumed by: webpack DefinePlugin (baked into the JS bundle at build time)
# Development: http://localhost/your-wp-install  or  http://localhost:8080
# Production:  https://drywalltoolbox.com
REACT_APP_WP_BASE_URL=https://drywalltoolbox.com

# ─── WooCommerce Application Password (SPA runtime auth) ─────────────────────
# The SPA uses these credentials to call the WC Store API (/wp-json/wc/store/v1)
# directly for cart/checkout flows, and as a fallback in services/api.js and
# data/products.js. They are baked into the bundle at build time.
#
# These are Application Password credentials (NOT the consumer key/secret).
# The username is the WordPress login username; the password is the generated
# Application Password string (xxxx xxxx xxxx xxxx xxxx xxxx format).
#
# Generate: WP Admin → Users → (your user) → Application Passwords → Add New.
# Server-side counterpart: DTB_WC_AUTH_USER / DTB_WC_AUTH_PASS in wp-config.php
#   (used by dtb/v1/config to return these to the SPA at runtime — same values).
# Consumed by: services/api.js, data/products.js, webpack DefinePlugin
REACT_APP_WC_AUTH_USER=your_wp_username
REACT_APP_WC_AUTH_PASS=xxxx xxxx xxxx xxxx xxxx xxxx

# ─── WooCommerce REST API base URL ────────────────────────────────────────────
# WooCommerce REST API base URL (v3).
# Consumed by: services/api.js, data/products.js, webpack DefinePlugin
# NOTE: WordPress lives at /wp — so the REST path is /wp/wp-json/wc/v3, not /wp-json/wc/v3.
REACT_APP_WC_BASE_URL=https://drywalltoolbox.com/wp/wp-json/wc/v3

# ─── Headless WooCommerce Proxy ────────────────────────────────────────────────
# Base URL for all drywall/v1 proxy routes (dtb-rest-api.php mu-plugin).
# Also used as the base for JWT auth and Store API calls.
# Development: http://localhost/your-wp-install
# Production:  https://drywalltoolbox.com
# Consumed by: api/auth.js, api/cart.js, webpack DefinePlugin
REACT_APP_API_BASE_URL=https://drywalltoolbox.com

# Path prefix for the WooCommerce Store API (cart, checkout).
# Never changes — always /wp/wp-json/wc/store/v1 relative to REACT_APP_API_BASE_URL.
# Consumed by: api/cart.js, webpack DefinePlugin
REACT_APP_STORE_API_BASE=/wp/wp-json/wc/store/v1

# JWT authentication endpoint path.
# Must match the active JWT plugin installed on the WordPress site:
#   simple-jwt-login plugin:               /wp/wp-json/simple-jwt-login/v1/auth
#   jwt-authentication-for-wp-rest-api:    /wp/wp-json/jwt-auth/v1/token
# Server-side counterpart: DRYWALL_JWT_SECRET in wp-config.php (signing key).
# Consumed by: api/auth.js, webpack DefinePlugin
REACT_APP_JWT_AUTH_ENDPOINT=/wp/wp-json/simple-jwt-login/v1/auth

# Build environment identifier — controls conditional behaviour at runtime.
# Accepted values: development | production
# Consumed by: webpack DefinePlugin
REACT_APP_ENV=development

# ─── Founding Member Promo Window ────────────────────────────────────────────
# ISO-8601 date string for the store launch date.
# isFoundingMemberWindowOpen() in api/membership.js uses this to determine
# whether the founding-member promotional pricing window is still active.
# Leave blank to disable the promo window entirely.
# Example: REACT_APP_STORE_LAUNCH_DATE=2026-06-01T00:00:00Z
REACT_APP_STORE_LAUNCH_DATE=

# ─── Veeqo (server-side API key auth only) ───────────────────────────────────
# Veeqo authentication is strictly API key — there is no OAuth flow.
# All Veeqo API calls originate from the WordPress server (dtb-veeqo.php).
# No Veeqo variables belong in the browser bundle or this file.
#
# The following server-only constants belong in wp-config.php § 9i:
#     DTB_VEEQO_API_KEY        — Veeqo REST API key (Settings → API Keys)
#     DTB_VEEQO_WEBHOOK_SECRET — HMAC-SHA256 hex secret matching Veeqo webhook config
#     DTB_VEEQO_WAREHOUSE_ID   — integer warehouse ID from Veeqo → Warehouses
#     DTB_VEEQO_CHANNEL_ID     — integer channel ID from Veeqo → Settings → Channels
#    Without all four constants the Veeqo integration silently no-ops.