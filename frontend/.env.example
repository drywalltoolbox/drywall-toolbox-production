# Veeqo Integration
VITE_VEEQO_CLIENT_ID=your_veeqo_client_id_here
VITE_VEEQO_CLIENT_SECRET=your_veeqo_client_secret_here
VITE_VEEQO_REDIRECT_URI=http://localhost:5173/veeqo/callback

# WooCommerce Integration (REST API with Application Passwords)
# Create in WP Admin → Settings → WooCommerce → Advanced → REST API
VITE_WOOCOMMERCE_STORE_URL=https://your-store.com/wp
VITE_WOOCOMMERCE_CONSUMER_KEY=ck_your_consumer_key_here
VITE_WOOCOMMERCE_CONSUMER_SECRET=cs_your_consumer_secret_here

# ─── HostGator / Headless WordPress + WooCommerce deployment ─────────────────
# These variables are read by src/services/api.js and src/api/wordpress.js and
# injected at build time by webpack DefinePlugin.  In production they are set
# as GitHub Actions secrets.  NEVER commit real values — this file is a
# template only.

# WordPress site root URL (used by src/api/wordpress.js for WP REST API calls)
#   e.g. https://drywalltoolbox.com
REACT_APP_WP_BASE_URL=https://your-domain.com

# WooCommerce REST API base URL (used by src/services/api.js)
#   Format: {site-root}/wp-json/wc/v3
#   e.g. https://drywalltoolbox.com/wp-json/wc/v3
REACT_APP_WC_BASE_URL=https://your-domain.com/wp-json/wc/v3

# WooCommerce Application Password authentication (more secure than consumer keys)
# Create in WP Admin → Settings → WooCommerce → Advanced → REST API → App Passwords
# Username: typically your WordPress admin username or a dedicated app user
REACT_APP_WC_AUTH_USER=your_app_password_username
REACT_APP_WC_AUTH_PASS=your_app_password_string

# ─── GitHub Actions secrets required for production deploy ───────────────────
# Add these in GitHub → Settings → Secrets and variables → Actions:
#
#   Secret name                  Maps to
#   ─────────────────────────    ──────────────────────────────────────────────
#   REACT_APP_WP_BASE_URL        WordPress site root (e.g. https://…)
#   REACT_APP_WC_BASE_URL        WC REST API base   (e.g. https://…/wp-json/wc/v3)
#   REACT_APP_WC_AUTH_USER       WC App Password username
#   REACT_APP_WC_AUTH_PASS       WC App Password password
#   FTP_SERVER                   HostGator FTP hostname (e.g. ftp.your-domain.com)
#   FTP_USERNAME                 HostGator cPanel FTP username
#   FTP_PASSWORD                 HostGator cPanel FTP password
