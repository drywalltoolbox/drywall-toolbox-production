# Drywall Toolbox frontend environment template
#
# Browser configuration is public by definition: Webpack embeds REACT_APP_*
# values in downloadable JavaScript. Never place passwords, consumer keys,
# consumer secrets, webhook secrets, private keys, Veeqo keys, QuickBooks
# credentials, or server API keys in any frontend environment file.
#
# Local development: create frontend/.env.development (gitignored).
# Production: GitHub Actions supplies public configuration only.

# Public WordPress/API origin. The root /wp-json alias routes to WordPress in /wp.
REACT_APP_WP_BASE_URL=https://drywalltoolbox.com
REACT_APP_WP_API_BASE=https://drywalltoolbox.com/wp-json
REACT_APP_API_BASE_URL=https://drywalltoolbox.com
REACT_APP_DTB_API_BASE=/wp-json/dtb/v1

# Public WooCommerce endpoints. These URLs do not contain credentials.
REACT_APP_WC_BASE_URL=https://drywalltoolbox.com/wp-json/wc/v3
REACT_APP_WC_API_BASE=https://drywalltoolbox.com/wp-json/wc/v3
REACT_APP_STORE_API_BASE=/wp-json/wc/store/v1

# Public authentication endpoint paths.
REACT_APP_JWT_AUTH_ENDPOINT=/wp-json/simple-jwt-login/v1/auth
REACT_APP_JWT_ENDPOINT=https://drywalltoolbox.com/wp-json/simple-jwt-login/v1/auth

# Public site/build metadata.
REACT_APP_SITE_URL=https://drywalltoolbox.com
REACT_APP_APP_ENV=development
REACT_APP_ENV=development
REACT_APP_REWARDS_ENABLED=0
REACT_APP_CATALOG_SNAPSHOTS_ENABLED=0
REACT_APP_STORE_LAUNCH_DATE=
REACT_APP_DTB_CATALOG_PLATFORM=0

# Stripe publishable keys are designed for browser use. Secret keys are not.
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY

# Server-only configuration belongs in WordPress wp-config.php or secured host
# configuration, including WC_PROXY_CONSUMER_KEY/SECRET, DTB_WC_AUTH_USER/PASS,
# DRYWALL_JWT_SECRET, DTB_VEEQO_*, DTB_QBO_*, webhook secrets, and marketplace
# credentials.
