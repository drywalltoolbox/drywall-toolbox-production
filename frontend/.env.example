# ─── IMPORTANT: Environment-Specific Configuration ────────────────────────────
# This is a TEMPLATE ONLY — never edit this file for local development.
#
# For LOCAL DEV: Create frontend/.env.development (in .gitignore, never commit)
# For PRODUCTION: GitHub Actions uses GitHub Secrets (never reads .env files)
#
# Structure:
#   frontend/.env.example       ← Template (committed, no real secrets)
#   frontend/.env.development   ← Local dev config (NOT committed, .gitignore)
#   frontend/.env.production    ← Production template (NOT committed, .gitignore)
#   → GitHub Actions injects via Secrets, not .env files
#
# The webpack config automatically detects NODE_ENV and loads the right file.
# See LOCAL_DEV_WORKFLOW.md and CONTRIBUTING.md for details.

# ─── Veeqo Integration ─────────────────────────────────────────────────────────
REACT_APP_VEEQO_CLIENT_ID=your_veeqo_client_id_here
REACT_APP_VEEQO_CLIENT_SECRET=your_veeqo_client_secret_here
REACT_APP_VEEQO_REDIRECT_URI=http://localhost:3000/veeqo/callback

# ─── WooCommerce Integration (REST API with Application Passwords) ─────────────
# Create in WP Admin → Settings → WooCommerce → Advanced → REST API
REACT_APP_WOOCOMMERCE_STORE_URL=https://your-store.com/wp
REACT_APP_WOOCOMMERCE_CONSUMER_KEY=ck_your_consumer_key_here
REACT_APP_WOOCOMMERCE_CONSUMER_SECRET=cs_your_consumer_secret_here

# ─── HostGator / Headless WordPress + WooCommerce Deployment ─────────────────
# API Endpoints and Authentication
# Injected at build time by webpack DefinePlugin (webpack.config.cjs).
#
# For DEVELOPMENT: Set in frontend/.env.development
# For PRODUCTION:  GitHub Actions injects via Secrets (not .env files)

# WordPress site root URL
REACT_APP_WP_BASE_URL=https://drywalltoolbox.com

# WooCommerce REST API base URL
REACT_APP_WC_BASE_URL=https://drywalltoolbox.com/wp-json/wc/v3

# WooCommerce Application Password authentication
# Create in WP Admin → Users → Edit user → Application Passwords
REACT_APP_WC_AUTH_USER=your_app_password_username
REACT_APP_WC_AUTH_PASS=your_app_password_string

# ─── Product Catalog CSV Fallback ─────────────────────────────────────────────
# Loading strategy (first success wins):
#
#   1. WooCommerce REST API     (/wp-json/wc/v3/products)
#   2. PHP proxy CSV endpoint   (/wp-json/dtb/v1/products-csv)
#   3. Web-root CSV fallback    (/wp-catalog.csv)
#
# For LOCAL DEVELOPMENT: Override with local CSV via REACT_APP_USE_LOCAL_CSV=true
# in frontend/.env.development. See LOCAL_DEV_WORKFLOW.md for details.

REACT_APP_WC_CSV_URL=

# ─── Local Development Mode ────────────────────────────────────────────────────
# Set to 'true' ONLY in frontend/.env.development to load from /public/wp-catalog.csv
# This enables offline development without hitting the live WooCommerce API.
# NEVER set this in production builds — GitHub Actions doesn't use .env files.

REACT_APP_USE_LOCAL_CSV=false

# ─── Headless WooCommerce Proxy (Section 2 API client) ────────────────────────
# REACT_APP_API_BASE_URL  — Base URL for the drywall/v1 server-side proxy.
#   Development: http://localhost/your-wp-install
#   Production:  https://drywalltoolbox.com
REACT_APP_API_BASE_URL=https://drywalltoolbox.com

# REACT_APP_STORE_API_BASE — Path prefix for the WooCommerce Store API.
#   Never changes; always /wp-json/wc/store/v1 relative to REACT_APP_API_BASE_URL.
REACT_APP_STORE_API_BASE=/wp-json/wc/store/v1

# REACT_APP_JWT_AUTH_ENDPOINT — Path to the JWT authentication endpoint.
#   Must match the active JWT plugin installed on the WordPress site.
#   simple-jwt-login: /wp-json/simple-jwt-login/v1/auth
#   jwt-authentication-for-wp-rest-api: /wp-json/jwt-auth/v1/token
REACT_APP_JWT_AUTH_ENDPOINT=/wp-json/simple-jwt-login/v1/auth

# REACT_APP_ENV — Build environment identifier (development | production).
REACT_APP_ENV=development