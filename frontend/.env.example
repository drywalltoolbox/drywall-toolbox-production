# Veeqo Integration
VITE_VEEQO_CLIENT_ID=your_veeqo_client_id_here
VITE_VEEQO_CLIENT_SECRET=your_veeqo_client_secret_here
VITE_VEEQO_REDIRECT_URI=http://localhost:5173/veeqo/callback

# WooCommerce Integration (REST API with Application Passwords)
# Create in WP Admin → Settings → WooCommerce → Advanced → REST API
VITE_WOOCOMMERCE_STORE_URL=https://your-store.com/wp
VITE_WOOCOMMERCE_CONSUMER_KEY=ck_your_consumer_key_here
VITE_WOOCOMMERCE_CONSUMER_SECRET=cs_your_consumer_secret_here

# ─── HostGator / Headless WordPress + WooCommerce deployment ─────────────────
# Injected at build time by webpack DefinePlugin (webpack.config.cjs).
# In production these are set as GitHub Actions secrets.
# NEVER commit real values — this file is a template only.
#
# NOTE: This project uses WEBPACK, not Vite.  Both REACT_APP_* (primary) and
# VITE_* (DefinePlugin shim) naming conventions are supported.  Prefer the
# REACT_APP_* keys for anything new; the VITE_* shims exist for backward
# compatibility with files that already use import.meta.env.VITE_* syntax.

# WordPress site root URL
REACT_APP_WP_BASE_URL=https://drywalltoolbox.com
VITE_WP_API_BASE=https://drywalltoolbox.com/wp-json/

# WooCommerce REST API base URL
REACT_APP_WC_BASE_URL=https://drywalltoolbox.com/wp-json/wc/v3
VITE_WC_API_BASE=https://drywalltoolbox.com/wp-json/wc/v3

# WooCommerce Application Password authentication
# Create in WP Admin → Users → Edit user → Application Passwords
REACT_APP_WC_AUTH_USER=your_app_password_username
REACT_APP_WC_AUTH_PASS=your_app_password_string
VITE_WC_AUTH_USER=your_app_password_username
VITE_WC_AUTH_PASS=your_app_password_string

# ─── Product catalog CSV fallback ────────────────────────────────────────────
# Optional. When the WooCommerce REST API is unavailable the frontend fetches
# the WooCommerce product-import CSV directly from the server.
#
# Resolution order (first non-empty value wins):
#   1. REACT_APP_WC_CSV_URL  (set this in GitHub Actions secrets)
#   2. VITE_WC_CSV_URL       (DefinePlugin shim — same value, different name)
#   3. GET /wp-json/dtb/v1/catalog → returns the filename dynamically
#   4. Hard-coded path: <origin>/wp-content/uploads/wc-imports/product-woocommerce_products_import-pjzmqbe2sf.csv
#
# Typically you do NOT need to set these — the PHP endpoint (step 3) handles it.
# Only set explicitly if you want to pin a specific URL.
REACT_APP_WC_CSV_URL=
VITE_WC_CSV_URL=

# ─── GitHub Actions secrets required for production deploy ───────────────────
# Add these in GitHub → Settings → Secrets and variables → Actions:
#
#   Secret name                  Maps to
#   ─────────────────────────    ──────────────────────────────────────────────
#   REACT_APP_WP_BASE_URL        WordPress site root
#   REACT_APP_WC_BASE_URL        WC REST API base
#   REACT_APP_WC_AUTH_USER       WC App Password username
#   REACT_APP_WC_AUTH_PASS       WC App Password password
#   REACT_APP_WC_CSV_URL         (optional) explicit CSV URL override
#   VITE_WP_API_BASE             Same as REACT_APP_WP_BASE_URL + /wp-json/
#   VITE_WC_API_BASE             Same as REACT_APP_WC_BASE_URL
#   VITE_WC_AUTH_USER            Same as REACT_APP_WC_AUTH_USER
#   VITE_WC_AUTH_PASS            Same as REACT_APP_WC_AUTH_PASS
#   VITE_WC_CSV_URL              (optional) same as REACT_APP_WC_CSV_URL
#   FTP_SERVER                   HostGator FTP hostname
#   FTP_USERNAME                 HostGator cPanel FTP username
#   FTP_PASSWORD                 HostGator cPanel FTP password
