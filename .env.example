# Veeqo Integration
VITE_VEEQO_CLIENT_ID=your_veeqo_client_id_here
VITE_VEEQO_CLIENT_SECRET=your_veeqo_client_secret_here
VITE_VEEQO_REDIRECT_URI=http://localhost:5173/veeqo/callback

# WooCommerce Integration (legacy settings UI)
VITE_WOOCOMMERCE_STORE_URL=https://your-store.com/wp
VITE_WOOCOMMERCE_CONSUMER_KEY=ck_your_consumer_key_here
VITE_WOOCOMMERCE_CONSUMER_SECRET=cs_your_consumer_secret_here

# ─── HostGator / Headless WordPress deployment ────────────────────────────────
# These variables are read by src/api/wordpress.js and injected at build time
# by webpack DefinePlugin.  In production they are set as GitHub Actions secrets.
# NEVER commit real values — this file is a template only.
#
# REACT_APP_WP_BASE_URL: full URL to the WordPress /wp subdirectory
#   e.g. https://drywalltoolbox.com/wp
REACT_APP_WP_BASE_URL=https://your-domain.com/wp

# WooCommerce REST API key pair (generated in WP Admin → WooCommerce → Settings
# → Advanced → REST API).  Requires Read/Write permissions.
REACT_APP_WC_CONSUMER_KEY=ck_your_consumer_key_here
REACT_APP_WC_CONSUMER_SECRET=cs_your_consumer_secret_here

# ─── GitHub Actions secrets required for production deploy ───────────────────
# Add these in GitHub → Settings → Secrets and variables → Actions:
#
#   Secret name                  Maps to
#   ─────────────────────────    ──────────────────────────────────────────────
#   REACT_APP_WP_BASE_URL        Full URL to /wp subdir (e.g. https://…/wp)
#   REACT_APP_WC_CONSUMER_KEY    WooCommerce consumer key  (ck_…)
#   REACT_APP_WC_CONSUMER_SECRET WooCommerce consumer secret (cs_…)
#   FTP_SERVER                   HostGator FTP hostname (e.g. ftp.your-domain.com)
#   FTP_USERNAME                 HostGator cPanel FTP username
#   FTP_PASSWORD                 HostGator cPanel FTP password
