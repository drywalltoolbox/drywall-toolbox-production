# ─── Drywall Toolbox — Production .htaccess ──────────────────────────────────
# Headless WordPress + React SPA architecture (CORRECTED VERSION)
#
# Architecture:
#   Domain Root (public_html/)
#   ├── index.html              ← React SPA shell (served by catch-all rule)
#   ├── assets/                 ← React compiled assets (JS/CSS/images)
#   ├── .htaccess               ← This file
#   ├── wp/                     ← WordPress subdirectory
#   │   ├── wp-admin/           ← WordPress admin
#   │   ├── wp-includes/        ← WordPress core
#   │   ├── wp-content/         ← Themes, plugins, uploads
#   │   ├── wp-config.php       ← Database config
#   │   └── index.php           ← WordPress entry point
#   └── wp-json/ → wp/wp-json/  ← Rewritten convenience alias
#
# Traffic Routing Rules:
#   1. /wp/*                    → WordPress (in /wp/ subdirectory)
#   2. /wp-json/*               → WordPress REST API (convenience alias)
#   3. /wp-admin/*, /wp-login/* → WordPress admin panel
#   4. /assets/*                → Static files (served directly, no rewrite)
#   5. Everything else          → dist/index.html (React SPA catch-all)

# ─── Directory Index ──────────────────────────────────────────────────────────
# During the pre-launch (coming-soon) phase, serve coming-soon.html as the
# default document for any directory request — most importantly the root "/".
# REMOVE or comment out this line when deploying the full React SPA (index.html).
DirectoryIndex coming-soon.html index.html index.php

# ─── Disable Directory Listing & Defaults ─────────────────────────────────────
# Disable directory indexing globally for security
Options -Indexes
Options +FollowSymLinks

# ─── Security Headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    # Extended HSTS max-age: 2 years with preload
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

    # ── Cache-Control for REST API routes ────────────────────────────────────
    # Cart, order, and auth endpoints must never be cached anywhere.
    <LocationMatch "^/(wp-json|dtb)(/|$)">
        Header always set Cache-Control "no-store, no-cache, must-revalidate, private"
        Header always set Pragma "no-cache"
    </LocationMatch>

    # ── Prevent search engines from indexing WP Admin ─────────────────────────
    <LocationMatch "^/(wp-admin(/|$)|wp-login\.php)">
        Header always set X-Robots-Tag "noindex, nofollow"
    </LocationMatch>
</IfModule>

# ─── WP Admin & Login Protection ──────────────────────────────────────────────
# Restrict access to /wp-admin/ and /wp-login.php using HTTP Basic
# Authentication.  Create /wp/.htpasswd on the server with:
#   htpasswd -c /home/<user>/public_html/drywalltoolbox/.htpasswd admin
# Then uncomment the AuthType block below.
#
# Alternatively, restrict by IP — replace the AuthType block with:
#   Require ip 1.2.3.4 5.6.7.8
#
<LocationMatch "^/(wp-admin(/|$)|wp-login\.php)">
    # Uncomment and configure to enable HTTP Basic Auth gate on WP Admin.
    # This adds a second authentication layer on top of WordPress login.
    #
    # AuthType Basic
    # AuthName "Restricted Area"
    # AuthUserFile /home/<cpanel_user>/public_html/drywalltoolbox/.htpasswd
    # Require valid-user

    # ── IP allowlist (alternative to Basic Auth) ──────────────────────────
    # Uncomment and add your admin IP addresses to lock down WP Admin.
    # Require ip 1.2.3.4
    # Require ip 5.6.7.0/24
</LocationMatch>

# ─── REST API Origin Guard ─────────────────────────────────────────────────────
# Block cross-origin REST API requests from domains NOT in the DTB allowlist.
# This protects against unauthorized third-party sites calling the API from a
# browser.  Server-to-server calls (no Origin header) are always allowed.
#
# Allowlist:
#   https://drywalltoolbox.com
#   https://www.drywalltoolbox.com
#   http://localhost:*   (development only — Apache env check)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the Origin header is present and is NOT our production domain…
    RewriteCond %{HTTP:Origin} .+ [NC]
    RewriteCond %{HTTP:Origin} !^https?://(www\.)?drywalltoolbox\.com$ [NC]
    # …and NOT a localhost/loopback origin (dev builds)…
    RewriteCond %{HTTP:Origin} !^http://(localhost|127\.0\.0\.1)(:[0-9]+)?$ [NC]
    # …then deny the REST API and DTB namespace routes with 403 Forbidden.
    RewriteRule ^(wp-json|dtb)/ - [F,L]
</IfModule>

# ─── CORS Headers ─────────────────────────────────────────────────────────────
# CORS for the REST API is handled dynamically by dtb-cors.php (mu-plugin) so
# that the reflected origin header is allowlisted correctly for both production
# and local-dev origins.  Static Apache headers here would conflict with the
# PHP-emitted headers and break cross-origin preflight for localhost.
#
# Only static-asset cross-origin requests (fonts, images) benefit from a fixed
# header, which is set here scoped to the uploads and asset paths.
<IfModule mod_headers.c>
    <LocationMatch "\.(woff2?|ttf|otf|eot|svg|webp|png|jpe?g|gif)$">
        Header set Access-Control-Allow-Origin "https://drywalltoolbox.com"
        Header set Vary "Origin"
    </LocationMatch>
</IfModule>

# ─── Gzip / Brotli Compression ────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2

    # Exclude already-compressed formats
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|gz|zip|exe)$ no-gzip
</IfModule>

# ─── Browser Caching ──────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML (React SPA shell) — NO caching
    # Reason: index.html contains hashed asset references;
    #         stale index.html would load old/missing JS/CSS chunks
    ExpiresByType text/html                "access plus 0 seconds"

    # Content-hashed assets — very long TTL (1 year)
    # These filenames include content hash, so they're cache-safe forever
    ExpiresByType text/css                 "access plus 1 year"
    ExpiresByType application/javascript   "access plus 1 year"
    ExpiresByType image/svg+xml            "access plus 1 year"
    ExpiresByType image/png                "access plus 1 year"
    ExpiresByType image/jpeg               "access plus 1 year"
    ExpiresByType image/webp               "access plus 1 year"
    ExpiresByType image/gif                "access plus 1 year"
    ExpiresByType image/x-icon             "access plus 1 year"
    ExpiresByType font/woff2               "access plus 1 year"
    ExpiresByType font/woff                "access plus 1 year"

    # ✅ ADDED: Optimize favicon caching
    ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
    
    # API responses — NO caching
    # REST API results change frequently
    ExpiresByType application/json         "access plus 0 seconds"
    ExpiresByType application/xml          "access plus 0 seconds"
</IfModule>

# ─── ETag Handling (optimize cache validation) ────────────────────────────────
<IfModule mod_headers.c>
    Header edit ETag ^"(.*)"$  "$1-gzip"
    Header always append Vary Accept-Encoding
</IfModule>

# ─── Authorization Header Passthrough ────────────────────────────────────────
# HostGator (and many shared hosts) strip the Authorization header before PHP
# sees it, which causes WordPress Application Password authentication to always
# return 401. These two rules re-expose the raw header value as a server
# variable so that WordPress/PHP can reconstruct it.
#
# Rule 1: mod_rewrite passthrough (works on most Apache configs)
# Rule 2: SetEnvIf fallback (catches edge cases where mod_rewrite doesn't fire)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>
<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

# ─── URL Routing ──────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ── Force HTTPS (only do this once at the beginning) ──────────────
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # ── Coming-Soon homepage ──────────────────────────────────────────
    # Serve coming-soon.html for root "/" requests during pre-launch.
    # REMOVE this rule when the React SPA (index.html) replaces coming-soon.html.
    RewriteRule ^$ /coming-soon.html [L]

    # ── WordPress admin & login ──────────────────────────────────────
    # Map /wp-admin/ → /wp/wp-admin/ (transparent to client)
    RewriteRule ^wp-admin(/.*)?$  wp/wp-admin$1  [L]

    # Map /wp-login.php → /wp/wp-login.php
    RewriteRule ^wp-login\.php$   wp/wp-login.php  [L]

    # ── WordPress wp-content (uploads, plugins, themes) ───────────────
    # Map /wp-content/* → /wp/wp-content/*
    RewriteRule ^wp-content/(.*)$ wp/wp-content/$1  [L]

    # ── WordPress REST API convenience aliases ──────────────────────
    # Allow BOTH /wp-json/ and /wp/wp-json/ to reach WordPress
    # (more convenient than requiring /wp/wp-json/ in API calls)
    # IMPORTANT: This must be processed INTERNALLY, not as a regular file request
    RewriteRule ^wp-json/(.*)$     wp/index.php?rest_route=/$1  [QSA,L]

    # ── DTB custom REST namespace fallback ───────────────────────────
    # Safety net: if VITE_WP_API_BASE was built without /wp-json, the
    # frontend may call /dtb/v1/... directly. Route those to WP too.
    RewriteRule ^dtb/(.*)$         wp/index.php?rest_route=/dtb/$1  [QSA,L]

    # ── Direct REST API calls to /index.php ───────────────────────────
    # If someone accesses /index.php?rest_route=... directly (common for API clients),
    # rewrite it to /wp/index.php to reach WordPress
    RewriteCond %{QUERY_STRING} rest_route=
    RewriteRule ^index\.php$ wp/index.php [QSA,L]

    # ── WordPress XML feeds & sitemap ────────────────────────────────
    RewriteRule ^feed(/.*)?$       wp/index.php  [L,QSA]
    RewriteRule ^sitemap\.xml$     wp/sitemap.xml  [L,QSA]
    RewriteRule ^xmlrpc\.php$      wp/xmlrpc.php  [L]

    # ── Static files — served directly, NO rewrite ───────────────────
    # If file exists in filesystem, serve it as-is (don't rewrite)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # If directory exists in filesystem, don't rewrite
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ── React SPA catch-all ────────────────────────────────────────
    # Any request that is NOT an existing file, directory, or WordPress
    # path gets rewritten to /index.html so React Router handles it.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/wp/
    RewriteCond %{REQUEST_URI} !^/wp-admin/
    RewriteCond %{REQUEST_URI} !^/wp-login\.php
    RewriteCond %{REQUEST_URI} !^/wp-json/
    RewriteCond %{REQUEST_URI} !^/dtb/
    RewriteCond %{QUERY_STRING} !rest_route=
    RewriteRule ^ /index.html  [QSA,L]
</IfModule>

# ─── Error Documents ──────────────────────────────────────────────────────────
ErrorDocument 404 /index.html
# Note: This lets React Router handle 404s gracefully (React shows 404 page)



