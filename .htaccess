# ─── Drywall Toolbox — Production .htaccess ───────────────────────────────────
# Headless WordPress + React SPA architecture
#
# Traffic routing:
#   /wp/*               → WordPress (in /wp/ subdirectory)
#   /wp-json/*          → WordPress REST API (convenience alias)
#   /dist/assets/*      → Static files served directly (no rewrite)
#   Everything else     → dist/index.html (React SPA catch-all)

# Disable directory listing
Options -Indexes

# ─── Force HTTPS ──────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect HTTP → HTTPS (skip if already HTTPS or on localhost)
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# ─── Security Headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ─── Gzip / Brotli Compression ────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ─── Browser Caching ──────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    # HTML — no caching for SPA shell (index.html contains hashed asset references;
    # a stale index.html would try to load old JS/CSS hashes that may no longer exist)
    ExpiresByType text/html                "access plus 0 seconds"
    # Content-hashed assets — very long TTL
    ExpiresByType text/css                 "access plus 1 year"
    ExpiresByType application/javascript   "access plus 1 year"
    ExpiresByType image/svg+xml            "access plus 1 year"
    ExpiresByType image/png                "access plus 1 year"
    ExpiresByType image/jpeg               "access plus 1 year"
    ExpiresByType image/webp               "access plus 1 year"
    ExpiresByType image/gif                "access plus 1 year"
    ExpiresByType font/woff2               "access plus 1 year"
    ExpiresByType font/woff                "access plus 1 year"
    ExpiresByType application/json         "access plus 0 seconds"
</IfModule>

# ─── URL Routing ──────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ── WordPress admin & login ──────────────────────────────────────────────
    # Route /wp-admin/ → /wp/wp-admin/ transparently
    RewriteRule ^wp-admin(/.*)?$  wp/wp-admin$1  [L]
    # Route /wp-login.php → /wp/wp-login.php
    RewriteRule ^wp-login\.php$   wp/wp-login.php  [L]

    # ── WordPress wp-content (uploads, plugins, themes) ─────────────────────
    RewriteRule ^wp-content/(.*)$ wp/wp-content/$1  [L]

    # ── WordPress REST API convenience aliases ───────────────────────────────
    # Allow both /wp-json/ and /wp/wp-json/ to reach WordPress
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^wp-json/(.*)$     wp/wp-json/$1  [L,QSA]

    # ── WordPress XML feeds & sitemap ────────────────────────────────────────
    RewriteRule ^feed(/.*)?$       wp/index.php  [L,QSA]
    RewriteRule ^sitemap\.xml$     wp/sitemap.xml  [L,QSA]
    RewriteRule ^xmlrpc\.php$      wp/xmlrpc.php  [L]

    # ── Static dist assets — served directly, no rewrite ────────────────────
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # ── React SPA catch-all ──────────────────────────────────────────────────
    # Any request that doesn't match an existing file or directory
    # and is not a WordPress path → serve dist/index.html for React Router.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/wp/
    RewriteRule ^ dist/index.html  [QSA,L]
</IfModule>
