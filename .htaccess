# ─── Drywall Toolbox — Production .htaccess ──────────────────────────────────
# Headless WordPress + React SPA architecture (CORRECTED VERSION)
#
# Architecture:
#   Domain Root (public_html/)
#   ├── index.html              ← React SPA shell (served by catch-all rule)
#   ├── assets/                 ← React compiled assets (JS/CSS/images)
#   ├── .htaccess               ← This file
#   ├── wp/                     ← WordPress subdirectory
#   │   ├── wp-admin/           ← WordPress admin
#   │   ├── wp-includes/        ← WordPress core
#   │   ├── wp-content/         ← Themes, plugins, uploads
#   │   ├── wp-config.php       ← Database config
#   │   └── index.php           ← WordPress entry point
#   └── wp-json/ → wp/wp-json/  ← Rewritten convenience alias
#
# Traffic Routing Rules:
#   1. /wp/*                    → WordPress (in /wp/ subdirectory)
#   2. /wp-json/*               → WordPress REST API (convenience alias)
#   3. /wp-admin/*, /wp-login/* → WordPress admin panel
#   4. /assets/*                → Static files (served directly, no rewrite)
#   5. Everything else          → dist/index.html (React SPA catch-all)

# ─── Directory Index ──────────────────────────────────────────────────────────
# index.html at the domain root serves the coming-soon page (pre-launch).
# When the React SPA is deployed, index.html becomes the SPA shell.
DirectoryIndex index.html index.php

# ─── Disable Directory Listing & Defaults ─────────────────────────────────────
# Disable directory indexing globally for security
Options -Indexes
Options +FollowSymLinks

# ─── Security Headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    # Extended HSTS max-age: 2 years with preload
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
</IfModule>

# ── Cache-Control for REST API routes ─────────────────────────────────────────
# Cart, order, and auth endpoints must never be cached anywhere.
# SetEnvIf is used because <LocationMatch> is not permitted in .htaccess on
# shared hosting. The env var is set when the URI matches, then the Header
# directive fires only when the env var is present.
<IfModule mod_setenvif.c>
    SetEnvIf Request_URI "^/(wp-json|dtb)(/|$)" IS_API_ROUTE=1
</IfModule>
<IfModule mod_headers.c>
    Header always set Cache-Control "no-store, no-cache, must-revalidate, private" env=IS_API_ROUTE
    Header always set Pragma "no-cache" env=IS_API_ROUTE
</IfModule>

# ── Prevent search engines from indexing WP Admin ─────────────────────────────
<IfModule mod_setenvif.c>
    SetEnvIf Request_URI "^/(wp-admin(/|$)|wp-login\.php)" IS_WP_ADMIN=1
</IfModule>
<IfModule mod_headers.c>
    Header always set X-Robots-Tag "noindex, nofollow" env=IS_WP_ADMIN
</IfModule>

# ─── WP Admin & Login Protection ──────────────────────────────────────────────
# Restrict access to /wp-admin/ and /wp-login.php using HTTP Basic
# Authentication.  Create /wp/.htpasswd on the server with:
#   htpasswd -c /home/<user>/public_html/drywalltoolbox/.htpasswd admin
# Then uncomment the AuthType block below.
#
# Alternatively, restrict by IP — replace the AuthType block with:
#   Require ip 1.2.3.4 5.6.7.8
#
# Note: Auth/Require directives for specific paths require either a per-directory
# .htaccess inside /wp/wp-admin/, or mod_rewrite conditions. Uncomment as needed.
#
# AuthType Basic
# AuthName "Restricted Area"
# AuthUserFile /home/<cpanel_user>/public_html/drywalltoolbox/.htpasswd
# Require valid-user

# ─── REST API Origin Guard ─────────────────────────────────────────────────────
# Block CROSS-ORIGIN REST API requests from domains NOT in the DTB allowlist.
# This protects against unauthorized third-party sites calling the API from a
# browser.
#
# IMPORTANT: Only blocks if Origin header is present AND doesn't match allowlist.
# Same-origin requests (no Origin header, or Origin = drywalltoolbox.com)
# are always allowed, including wp-admin internal API calls.
#
# Allowlist:
#   https://drywalltoolbox.com        (production domain — same-origin)
#   https://www.drywalltoolbox.com    (production domain alias)
#   https://elliotttmiller.github.io  (GitHub Pages dev build)
#   http://localhost:*                (local dev)
#   http://127.0.0.1:*                (local dev)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # ONLY apply origin guard if ALL of these are true:
    # 1. Origin header is present (cross-origin request)
    RewriteCond %{HTTP:Origin} .+ [NC]
    # 2. Origin is NOT production domain (allow www and non-www)
    RewriteCond %{HTTP:Origin} !^https?://(www\.)?drywalltoolbox\.com(:|/|$) [NC]
    # 3. Origin is NOT localhost/loopback (dev)
    RewriteCond %{HTTP:Origin} !^http://(localhost|127\.0\.0\.1)(:|$) [NC]
    # 4. Origin is NOT GitHub Pages dev build
    RewriteCond %{HTTP:Origin} !^https://elliotttmiller\.github\.io(:|/|$) [NC]
    # THEN deny cross-origin REST/DTB requests
    RewriteRule ^(wp-json|dtb)/ - [F,L]
</IfModule>

# ─── CORS Headers ─────────────────────────────────────────────────────────────
# CORS for the REST API is handled dynamically by dtb-cors.php (mu-plugin) so
# that the reflected origin header is allowlisted correctly for both production
# and local-dev origins.  Static Apache headers here would conflict with the
# PHP-emitted headers and break cross-origin preflight for localhost.
#
# Only static-asset cross-origin requests (fonts, images) benefit from a fixed
# header, which is set here scoped by file extension via <FilesMatch>.
# (<LocationMatch> is not permitted in .htaccess on shared hosting.)
<IfModule mod_headers.c>
    <FilesMatch "\.(woff2?|ttf|otf|eot|svg|webp|png|jpe?g|gif)$">
        Header set Access-Control-Allow-Origin "https://drywalltoolbox.com"
        Header set Vary "Origin"
    </FilesMatch>
</IfModule>

# ─── Gzip / Brotli Compression ────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2

    # Exclude already-compressed formats
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|gz|zip|exe)$ no-gzip
</IfModule>

# ─── Browser Caching ──────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML (React SPA shell) — NO caching
    # Reason: index.html contains hashed asset references;
    #         stale index.html would load old/missing JS/CSS chunks
    ExpiresByType text/html                "access plus 0 seconds"

    # Content-hashed assets — very long TTL (1 year)
    # These filenames include content hash, so they're cache-safe forever
    ExpiresByType text/css                 "access plus 1 year"
    ExpiresByType application/javascript   "access plus 1 year"
    ExpiresByType image/svg+xml            "access plus 1 year"
    ExpiresByType image/png                "access plus 1 year"
    ExpiresByType image/jpeg               "access plus 1 year"
    ExpiresByType image/webp               "access plus 1 year"
    ExpiresByType image/gif                "access plus 1 year"
    ExpiresByType image/x-icon             "access plus 1 year"
    ExpiresByType font/woff2               "access plus 1 year"
    ExpiresByType font/woff                "access plus 1 year"

    # ✅ ADDED: Optimize favicon caching
    ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
    
    # API responses — NO caching
    # REST API results change frequently
    ExpiresByType application/json         "access plus 0 seconds"
    ExpiresByType application/xml          "access plus 0 seconds"
</IfModule>

# ─── ETag Handling (optimize cache validation) ────────────────────────────────
<IfModule mod_headers.c>
    Header edit ETag ^"(.*)"$  "$1-gzip"
    Header always append Vary Accept-Encoding
</IfModule>

# ─── Authorization Header Passthrough ────────────────────────────────────────
# HostGator (and many shared hosts) strip the Authorization header before PHP
# sees it, which causes WordPress Application Password authentication to always
# return 401. These two rules re-expose the raw header value as a server
# variable so that WordPress/PHP can reconstruct it.
#
# Rule 1: mod_rewrite passthrough (works on most Apache configs)
# Rule 2: SetEnvIf fallback (catches edge cases where mod_rewrite doesn't fire)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>
<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

# ─── URL Routing ──────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ── Force HTTPS (only do this once at the beginning) ──────────────
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # ── Root homepage ─────────────────────────────────────────────────
    # index.html at the root serves both the coming-soon page (pre-launch)
    # and the React SPA shell (post-launch) — same file, content swapped.
    RewriteRule ^$ /index.html [L]

    # ── Favicon — return empty 204 to suppress browser 500/404 loops ─
    # No favicon.ico exists at the root during pre-launch; returning 204
    # (No Content) silences the browser request cleanly without an error.
    RewriteRule ^favicon\.ico$ - [R=204,L]

    # ── WordPress admin & login ──────────────────────────────────────
    # Map /wp-admin/ → /wp/wp-admin/ (transparent to client)
    RewriteRule ^wp-admin(/.*)?$  wp/wp-admin$1  [L]

    # Map /wp-login.php → /wp/wp-login.php
    RewriteRule ^wp-login\.php$   wp/wp-login.php  [L]

    # ── WordPress wp-content (uploads, plugins, themes) ───────────────
    # Map /wp-content/* → /wp/wp-content/*
    RewriteRule ^wp-content/(.*)$ wp/wp-content/$1  [L]

    # ── WordPress REST API convenience aliases ──────────────────────
    # Allow BOTH /wp-json/ and /wp/wp-json/ to reach WordPress
    # (more convenient than requiring /wp/wp-json/ in API calls)
    # IMPORTANT: This must be processed INTERNALLY, not as a regular file request
    RewriteRule ^wp-json/(.*)$     wp/index.php?rest_route=/$1  [QSA,L]

    # ── DTB custom REST namespace fallback ───────────────────────────
    # Safety net: if VITE_WP_API_BASE was built without /wp-json, the
    # frontend may call /dtb/v1/... directly. Route those to WP too.
    RewriteRule ^dtb/(.*)$         wp/index.php?rest_route=/dtb/$1  [QSA,L]

    # ── Direct REST API calls to /index.php ───────────────────────────
    # If someone accesses /index.php?rest_route=... directly (common for API clients),
    # rewrite it to /wp/index.php to reach WordPress
    RewriteCond %{QUERY_STRING} rest_route=
    RewriteRule ^index\.php$ wp/index.php [QSA,L]

    # ── WordPress XML feeds & sitemap ────────────────────────────────
    RewriteRule ^feed(/.*)?$       wp/index.php  [L,QSA]
    RewriteRule ^xmlrpc\.php$      wp/xmlrpc.php  [L]

    # ── Sitemap & robots.txt — delegate to WordPress ─────────────────
    # Redirect /sitemap.xml and /sitemap_index.xml to WP's native sitemap (301).
    # WordPress generates the sitemap at /wp/wp-sitemap.xml by default.
    RewriteRule ^sitemap\.xml$          /wp/wp-sitemap.xml  [R=301,L]
    RewriteRule ^sitemap_index\.xml$    /wp/wp-sitemap.xml  [R=301,L]
    # Redirect /robots.txt to WordPress's dynamically generated robots.txt.
    RewriteRule ^robots\.txt$           /wp/robots.txt      [R=301,L]

    # ──────────────────────────────────────────────────────────────────
    # ── Prerender.io bot-detection (COMMENTED — enable once token set) ─
    #
    # Prerequisites:
    #   1. Sign up at https://prerender.io and obtain your token.
    #   2. Set PRERENDER_TOKEN to your token in the rule below.
    #   3. Uncomment the entire block.
    #   4. Deploy. Prerender will cache and serve pre-rendered HTML to bots.
    #
    # RewriteCond %{HTTP_USER_AGENT} (googlebot|bingbot|yandex|baiduspider|twitterbot|facebookexternalhit|rogerbot|linkedinbot|embedly|quora\ link\ preview|showyoubot|outbrain|pinterest\/0\.|developers\.google\.com\/\+\/web\/snippet|slackbot|vkShare|W3C_Validator|redditbot|Applebot|WhatsApp|flipboard|tumblr|bitlybot|SkypeUriPreview|nuzzel|Discordbot|Google\ Page\ Speed|Qwantify|pinterestbot|Telegrambot) [NC]
    # RewriteCond %{REQUEST_URI} !\.(js|css|xml|less|png|jpg|jpeg|gif|pdf|doc|txt|ico|rss|zip|mp3|rar|exe|wmv|avi|flv|ppt|ttf|ico|dwg|woff|woff2|svg|webp)$ [NC]
    # RewriteRule .* https://service.prerender.io/https://drywalltoolbox.com%{REQUEST_URI} [P,L]

    # ── Static files — served directly, NO rewrite ───────────────────
    # If file exists in filesystem, serve it as-is (don't rewrite)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # If directory exists in filesystem, don't rewrite
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ── React SPA catch-all ────────────────────────────────────────
    # Any request that is NOT an existing file, directory, or WordPress
    # path gets rewritten to /index.html so React Router handles it.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/wp/
    RewriteCond %{REQUEST_URI} !^/wp-admin/
    RewriteCond %{REQUEST_URI} !^/wp-login\.php
    RewriteCond %{REQUEST_URI} !^/wp-json/
    RewriteCond %{REQUEST_URI} !^/dtb/
    RewriteCond %{QUERY_STRING} !rest_route=
    RewriteRule ^ /index.html  [QSA,L]
</IfModule>

# ─── Cache-Control Headers ────────────────────────────────────────────────────
# HTML (SPA shell): short TTL — must revalidate on every load so stale shells
# never reference missing content-hashed chunks.
# Hashed JS/CSS assets: immutable long TTL — safe because filename = content hash.
<IfModule mod_headers.c>
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, must-revalidate"
    </FilesMatch>
    <FilesMatch "\.[0-9a-f]{8,}\.(js|css)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# ─── Error Documents ──────────────────────────────────────────────────────────
# During pre-launch: /index.html contains the coming-soon page content.
# When the React SPA ships, this stays as /index.html — React Router handles 404s.
ErrorDocument 404 /index.html



