node_modules/
.DS_Store
*.log
.vscode/
.idea/
dist/
build/
*.tmp
*.cache
coverage/
.amazonq
.venv

# Root-level env files — never commit real secrets
/.env
/.env.local
/.env.development
/.env.production

# frontend/ env files are committed (non-secret URL config only; no credentials)
# frontend/.env.development  — committed (localhost defaults)
# frontend/.env.production   — committed (production URLs; no secrets)
# Secrets (WC keys, JWT key, FTP credentials) live in GitHub Actions secrets only.

# frontend build artifacts
frontend/dist/
frontend/node_modules/

# ---------------------------------------------------------------
# WordPress — NEVER commit these files
# ---------------------------------------------------------------

# Core WordPress files (only themes/ and plugins/ belong in this repo)
wp-admin/
wp-includes/
wp-*.php
xmlrpc.php
license.txt
readme.html

# Sensitive configuration — provide snippets in README.md instead
wp-config.php
wp-config-local.php
wp-config-*.php

# WordPress uploads (binary assets; use Media Library, not Git)
wp-content/uploads/

# WordPress object/page cache
wp-content/cache/
wp-content/upgrade/
wp-content/backup-db/
wp-content/advanced-cache.php
wp-content/wp-cache-config.php

# WordPress core wp-content sub-directories (when a full WP install is present)
# wp-content/themes/drywall-toolbox/ IS tracked — it contains the theme's PHP
# source files (style.css, functions.php, index.php).
# wp-content/themes/headless-base/ IS tracked — new minimal headless theme.
# wp-content/mu-plugins/ IS tracked — CORS mu-plugin lives here.
# All other installed themes and all plugins are NOT part of this repo.
wp-content/themes/twenty*/
wp-content/themes/yith*/
wp-content/plugins/

# Composer / PHP dependency directories
vendor/

# OS artifacts
Thumbs.db
ehthumbs.db
Desktop.ini

