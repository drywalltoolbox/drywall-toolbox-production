# ---------------------------------------------------------------
# WordPress — NEVER commit these files
# ---------------------------------------------------------------

# Core WordPress files (only themes/ and plugins/ belong in this repo)
wp-admin/
wp-includes/
wp-*.php
xmlrpc.php
license.txt
readme.html

# Sensitive configuration — provide snippets in README.md instead
wp-config.php
wp-config-local.php
wp-config-*.php

# Server configuration — provide snippets in README.md instead
.htaccess

# WordPress uploads (binary assets; use Media Library, not Git)
wp-content/uploads/

# WordPress object/page cache
wp-content/cache/
wp-content/upgrade/
wp-content/backup-db/
wp-content/advanced-cache.php
wp-content/wp-cache-config.php

# WordPress core wp-content sub-directories (when a full WP install is present)
# wp-content/themes/drywall-toolbox/ IS tracked — it contains the theme's PHP
# source files (style.css, functions.php, index.php).  The dist/ subdirectory
# (webpack build output) is excluded by the top-level `dist/` rule above.
# All other installed themes (twentytwenty*, etc.) are not part of this repo.
wp-content/themes/twenty*/
wp-content/themes/yith*/
wp-content/plugins/

# Composer / PHP dependency directories
vendor/

# OS artifacts
Thumbs.db
ehthumbs.db
Desktop.ini

