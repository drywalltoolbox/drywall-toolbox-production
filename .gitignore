node_modules/
.DS_Store
*.log
.vscode/
.idea/
dist/
build/
*.tmp
*.cache
coverage/
.amazonq
.venv

# Root-level env files — never commit real secrets
/.env
/.env.local
/.env.development
/.env.production

# frontend/ env files — .env.example is committed (template only, no secrets)
# frontend/.env contains real credentials for local builds — NEVER commit it
frontend/.env
frontend/.env.local
frontend/.env.*.local

# frontend build artifacts
frontend/dist/
frontend/node_modules/

# ---------------------------------------------------------------
# WordPress — wp/ subdirectory (NEVER commit these files)
# ---------------------------------------------------------------
# WordPress core is installed in wp/ on the server, not tracked here.
# Tracked: wp/wp-content/themes/, wp/wp-content/mu-plugins/, wp/wp-config-sample.php

# WordPress core files (match anywhere in wp/ tree — wp-admin/, wp-includes/, etc.)
wp-admin/
wp-includes/
wp-*.php
xmlrpc.php
license.txt
readme.html

# Keep the sample config (wp-*.php above would otherwise exclude it)
!wp/wp-config-sample.php

# Sensitive configuration — configure manually on the server, never commit
wp-config.php
wp-config-local.php
wp-config-*.php
!wp/wp-config-sample.php

# WordPress uploads (binary assets; use Media Library, not Git)
wp-content/uploads/

# WordPress object/page cache and generated files
wp-content/cache/
wp-content/upgrade/
wp-content/backup-db/
wp-content/advanced-cache.php
wp-content/wp-cache-config.php

# WordPress content tracked in this repo (wp/wp-content/):
#   wp/wp-content/themes/drywall-toolbox/           — legacy theme (kept until headless-base validated)
#   wp/wp-content/themes/headless-base/             — active minimal headless theme (zero frontend output)
#   wp/wp-content/mu-plugins/dtb-cors.php           — CORS mu-plugin (auto-loaded)
#   wp/wp-content/mu-plugins/dtb-schematics-api.php — Schematic media manifest REST endpoint
# All other installed themes and all plugins are installed on the server only.
wp-content/themes/twenty*/
wp-content/themes/yith*/
wp-content/plugins/

# Composer / PHP dependency directories
vendor/

# ---------------------------------------------------------------
# Schematic images — managed via WordPress Media Library (WebP)
# ---------------------------------------------------------------
# Run scripts/convert_schematics_to_webp.py to convert PNG/JPG → WebP.
# Run scripts/upload_schematics_to_wp.py to upload to WP Media Library.
# After confirming all images are live in WP, delete the originals locally
# and these gitignore patterns will prevent them from being re-added.
#
# The schematic_data.json metadata files ARE tracked (small JSON, no binary).
public/brands/*/Schematics/**/*.png
public/brands/*/Schematics/**/*.jpg
public/brands/*/Schematics/**/*.jpeg
public/brands/*/Schematics/**/*.webp

# Local backup directories (large binary files — not needed in the repo)
# The originals live here after scripts/convert_schematics_to_webp.py backs them up.
# To restore: copy back from backups/ and re-run the upload script.
backups/

# Generated by scripts/process_catalog_images.py
image-manifest.csv

# OS artifacts
ehthumbs.db
Desktop.ini
