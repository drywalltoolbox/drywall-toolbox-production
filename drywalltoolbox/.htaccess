# Drywall Toolbox live root routing
# Document root: /public_html/drywalltoolbox/
# WordPress core: /public_html/drywalltoolbox/wp/
# React build: upload the CONTENTS of dist/ into this document root.

DirectoryIndex index.html index.php
Options -Indexes
Options +FollowSymLinks
FileETag None

ErrorDocument 400 /errors/400.html
ErrorDocument 401 /errors/401.html
ErrorDocument 402 /errors/402.html
ErrorDocument 403 /errors/403.html
ErrorDocument 404 /errors/404.html
ErrorDocument 405 /errors/405.html
ErrorDocument 406 /errors/406.html
ErrorDocument 408 /errors/408.html
ErrorDocument 409 /errors/409.html
ErrorDocument 410 /errors/410.html
ErrorDocument 411 /errors/411.html
ErrorDocument 412 /errors/412.html
ErrorDocument 413 /errors/413.html
ErrorDocument 414 /errors/414.html
ErrorDocument 415 /errors/415.html
ErrorDocument 416 /errors/416.html
ErrorDocument 417 /errors/417.html
ErrorDocument 421 /errors/421.html
ErrorDocument 422 /errors/422.html
ErrorDocument 423 /errors/423.html
ErrorDocument 424 /errors/424.html
ErrorDocument 426 /errors/426.html
ErrorDocument 428 /errors/428.html
ErrorDocument 429 /errors/429.html
ErrorDocument 431 /errors/431.html
ErrorDocument 451 /errors/451.html
ErrorDocument 500 /errors/500.html
ErrorDocument 501 /errors/501.html
ErrorDocument 502 /errors/502.html
ErrorDocument 503 /errors/503.html
ErrorDocument 504 /errors/504.html
ErrorDocument 505 /errors/505.html
ErrorDocument 507 /errors/507.html
ErrorDocument 508 /errors/508.html
ErrorDocument 511 /errors/511.html

# Block accidental public reads of secrets, backups, logs, and local build files.
<FilesMatch "(^\.|wp-config\.php$|\.env(?:\..*)?$|composer\.(?:json|lock)$|package-lock\.json$|package\.json$|.*\.(?:bak|backup|old|orig|save|sql|sqlite|log|ini|sh|ps1|pem|key)$)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Explicit MIME types prevent JS/CSS from being served as text/html by host defaults.
<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType application/json .json
  AddType application/manifest+json .webmanifest
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
  AddType font/woff .woff
  AddType text/plain .txt
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Preserve Authorization headers for PHP/WordPress auth handlers.
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

  # Bridge2Cart / Veeqo bridge — serve directly, skip all rewrites.
  RewriteRule ^bridge2cart/ - [L]

  # Force HTTPS in production.
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP_HOST} !^localhost$ [NC]
  RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$ [NC]
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Canonical host. Keep the public site and WordPress cookies on one host.
  RewriteCond %{HTTP_HOST} ^www\.drywalltoolbox\.com$ [NC]
  RewriteRule ^ https://drywalltoolbox.com%{REQUEST_URI} [R=301,L]

  # Apple Pay / Stripe / WooPayments domain-association verification.
  # The file must be non-empty. If WooPayments writes it under the WordPress
  # subdirectory because WP core lives in /wp, expose that non-empty generated
  # copy at the public domain-root .well-known URL Apple verifies.
  RewriteCond %{DOCUMENT_ROOT}/.well-known/apple-developer-merchantid-domain-association -s
  RewriteRule ^\.well-known/apple-developer-merchantid-domain-association$ .well-known/apple-developer-merchantid-domain-association [L]

  RewriteCond %{DOCUMENT_ROOT}/wp/.well-known/apple-developer-merchantid-domain-association -s
  RewriteRule ^\.well-known/apple-developer-merchantid-domain-association$ wp/.well-known/apple-developer-merchantid-domain-association [L]

  RewriteCond %{DOCUMENT_ROOT}/.well-known/apple-developer-merchantid-domain-association -s
  RewriteRule ^\.well-known/apple-developer-merchantid-domain-association\.txt$ .well-known/apple-developer-merchantid-domain-association [L]

  RewriteCond %{DOCUMENT_ROOT}/wp/.well-known/apple-developer-merchantid-domain-association -s
  RewriteRule ^\.well-known/apple-developer-merchantid-domain-association\.txt$ wp/.well-known/apple-developer-merchantid-domain-association [L]

  RewriteCond %{REQUEST_URI} ^/\.well-known/apple-developer-merchantid-domain-association(?:\.txt)?/?$ [NC]
  RewriteRule ^ - [R=404,L]

  # Route root/query-string REST fallback into WordPress before the SPA homepage.
  # Woo.com and some diagnostics probe ?rest_route=/ instead of /wp-json/.
  RewriteCond %{QUERY_STRING} (^|&)rest_route= [NC]
  RewriteRule ^$ wp/index.php [QSA,L]

  # Route direct rest_route=index.php calls into /wp/index.php.
  RewriteCond %{QUERY_STRING} (^|&)rest_route= [NC]
  RewriteRule ^index\.php$ wp/index.php [QSA,L]

  # Root REST aliases -> WordPress in /wp.
  RewriteRule ^wp-json/?$ wp/index.php?rest_route=/ [QSA,L]
  RewriteRule ^wp-json/(.*)$ wp/index.php?rest_route=/$1 [QSA,L]
  RewriteRule ^dtb/(.*)$ wp/index.php?rest_route=/dtb/$1 [QSA,L]

  # Staging REST aliases -> WordPress in /wp.
  # Prevent /staging/2972/wp-json/* from falling into the staging SPA shell.
  RewriteRule ^staging/2972/wp-json/?$ wp/index.php?rest_route=/ [QSA,L]
  RewriteRule ^staging/2972/wp-json/(.*)$ wp/index.php?rest_route=/$1 [QSA,L]
  RewriteRule ^staging/2972/dtb/(.*)$ wp/index.php?rest_route=/dtb/$1 [QSA,L]

  # Route staging rest_route query probes into WordPress as well.
  RewriteCond %{REQUEST_URI} ^/staging/2972/?$ [NC]
  RewriteCond %{QUERY_STRING} (^|&)rest_route= [NC]
  RewriteRule ^staging/2972/?$ wp/index.php [QSA,L]

  # WooCommerce legacy callback/API compatibility from the root URL space.
  RewriteCond %{QUERY_STRING} (^|&)wc-api= [NC]
  RewriteRule ^(?:index\.php)?$ wp/index.php [QSA,L]
  RewriteRule ^wc-api/?$ wp/index.php [QSA,L]
  RewriteRule ^staging/2972/wc-api/?$ wp/index.php [QSA,L]

  # Canonicalize wp-prefixed WooCommerce payment endpoints back to the public
  # checkout URL. WooCommerce order-pay is a checkout endpoint, not a React route;
  # when served under /wp/checkout/order-pay it can miss the public checkout page
  # context and fall through to the coming-soon/front-page template.
  RewriteRule ^wp/checkout/order-pay/(.*)$ /checkout/order-pay/$1 [R=302,L,QSA]
  RewriteRule ^wp/order-pay/(.*)$ /checkout/order-pay/$1 [R=302,L,QSA]

  # WooCommerce payment/order-pay endpoints must be handled by WordPress, not by
  # the React SPA shell. Without this rule, secure-payment redirects can fall
  # back into the public landing/coming-soon page instead of the payment runtime.
  # Pass the endpoint and order id explicitly. A bare wp/index.php handoff keeps
  # the original headless/staging REQUEST_URI, so WordPress can resolve it as a
  # 404 before WooCommerce registers the order-pay endpoint context.
  RewriteRule ^checkout/order-pay/([0-9]+)/?$ wp/index.php?pagename=checkout&order-pay=$1 [QSA,L]
  RewriteRule ^order-pay/([0-9]+)/?$ wp/index.php?pagename=checkout&order-pay=$1 [QSA,L]

  # Staging variants of the order-pay endpoint must also route to WordPress.
  RewriteRule ^staging/2972/checkout/order-pay/([0-9]+)/?$ wp/index.php?pagename=checkout&order-pay=$1 [QSA,L]

  # Reduced/query-string order-pay shape — e.g. checkout/?pay_for_order=true&key=wc_order_xxx
  # or checkout/?order-pay=123&key=wc_order_xxx. WooCommerce (and DTB checkout-confirm
  # "next" links) can legitimately emit this shape with no /order-pay/{id}/ path segment
  # at all (plain-permalink resolution, or a payment retry link built without pretty
  # rewrite context). Without this rule the request matches none of the conditions above
  # and silently falls through to the final SPA catch-all near the bottom of this file,
  # which serves the static coming-soon/SPA shell with a 200 OK and no error of any kind —
  # WordPress/WooCommerce never loads, so no PHP-level order-pay hardening can run either.
  RewriteCond %{QUERY_STRING} (^|&)(pay_for_order=true|order-pay=[0-9]+)(&|$) [NC]
  RewriteCond %{QUERY_STRING} (^|&)key=wc_order_ [NC]
  RewriteRule ^checkout/?$ wp/index.php?pagename=checkout [QSA,L]

  RewriteCond %{QUERY_STRING} (^|&)(pay_for_order=true|order-pay=[0-9]+)(&|$) [NC]
  RewriteCond %{QUERY_STRING} (^|&)key=wc_order_ [NC]
  RewriteRule ^staging/2972/checkout/?$ wp/index.php?pagename=checkout [QSA,L]

  # Signal Endurance/nginx cache to bypass customer/session-owned WooCommerce surfaces.
  <If "%{REQUEST_URI} =~ m#^/(?:cart|checkout|account|my-account|dashboard|orders|addresses|rewards|login|register|forgot-password|lost-password|reset-password|logout|wc-api)(?:/|$)#i || %{REQUEST_URI} =~ m#/checkout/order-pay/#i || %{QUERY_STRING} =~ m#(^|&)(?:pay_for_order=true|order-pay=[0-9]+|wc-api=)#i || %{HTTP_COOKIE} =~ m#(?:^|;\s*)(?:woocommerce_cart_hash|woocommerce_items_in_cart|wp_woocommerce_session_)#i">
    Header always set Set-Cookie "endurance-no-cache=1; Path=/; Max-Age=60; SameSite=Strict; Secure"
  </If>

  # Force homepage to the static React landing page after API fallbacks.
  RewriteRule ^$ index.html [L]

  # Conventional browser favicon path backed by the shared logo assets folder.
  RewriteRule ^favicon\.ico$ logos/favicon.ico [L]

  # WordPress admin/login aliases from the root URL space.
  RewriteRule ^wp-admin/?$ wp/wp-admin/ [L,QSA]
  RewriteRule ^wp-admin/(.*)$ wp/wp-admin/$1 [L,QSA]
  RewriteRule ^wp-login\.php$ wp/wp-login.php [L,QSA]

  # Expose WordPress asset/core paths at root for compatibility.
  RewriteRule ^wp-content/(.*)$ wp/wp-content/$1 [L,QSA]
  RewriteRule ^wp-includes/(.*)$ wp/wp-includes/$1 [L,QSA]
  RewriteRule ^wp-cron\.php$ wp/wp-cron.php [L,QSA]
  RewriteRule ^xmlrpc\.php$ wp/xmlrpc.php [L,QSA]

  # Staging SPA deep-link fallback.
  RewriteCond %{REQUEST_URI} ^/staging/2972/ [NC]
  RewriteCond %{REQUEST_URI} !^/staging/2972/(?:wp-json|dtb)(?:/|$) [NC]
  RewriteCond %{REQUEST_URI} !^/staging/2972/checkout/order-pay/ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^staging/2972/ /staging/2972/index.html [QSA,L]

  # Serve existing files/directories directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Keep direct /wp/* requests in WordPress' own rewrite scope.
  RewriteCond %{REQUEST_URI} ^/wp/ [NC]
  RewriteRule ^ - [L]

  # Do not serve the SPA shell for missing static assets or verification files.
  # Returning HTML for missing JS/CSS/provider verification paths causes blank
  # screens, MIME/type failures, and Apple Pay domain-verification failures.
  RewriteCond %{REQUEST_URI} (?:\.(?:css|js|mjs|map|json|webmanifest|png|jpe?g|gif|webp|avif|svg|ico|woff2?|ttf|otf|eot|pdf|txt|xml)$|^/\.well-known/) [NC]
  RewriteRule ^ - [R=404,L]

  # Root React Router SPA catch-all.
  RewriteRule ^ index.html [QSA,L]
</IfModule>

<IfModule mod_headers.c>
  Header unset ETag
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Permitted-Cross-Domain-Policies "none"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(self), usb=(), browsing-topics=()"
  Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"

  # HTML shell must revalidate so clients pick up newly deployed asset paths.
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  <FilesMatch "^[45][0-9]{2}\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Apple Pay / Stripe domain association files must not be cached aggressively
  # while verification is being repaired.
  <FilesMatch "^apple-developer-merchantid-domain-association$">
    Header set Content-Type "text/plain; charset=utf-8"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Stable JS/CSS/media asset names are deployment-controlled. Revalidate rather
  # than immutable-cache to avoid stale bundles on shared hosting/manual uploads.
  <FilesMatch "\.(?:js|mjs|css|json|webmanifest)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(?:png|jpe?g|gif|webp|avif|svg|ico|woff2?|woff|ttf|otf|eot|pdf)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # WooCommerce/session-owned surfaces and cookies must never be page-cached on HostGator.
  <If "%{REQUEST_URI} =~ m#^/(?:cart|checkout|account|my-account|dashboard|orders|addresses|rewards|login|register|forgot-password|lost-password|reset-password|logout|wc-api)(?:/|$)#i || %{REQUEST_URI} =~ m#/checkout/order-pay/#i || %{QUERY_STRING} =~ m#(^|&)(?:pay_for_order=true|order-pay=[0-9]+|wc-api=)#i || %{HTTP_COOKIE} =~ m#(?:^|;\s*)(?:woocommerce_cart_hash|woocommerce_items_in_cart|wp_woocommerce_session_)#i">
    Header set Cache-Control "no-cache, no-store, must-revalidate, private"
    Header set Pragma "no-cache"
    Header set Expires "0"
    Header set X-Accel-Expires "0"
  </If>
</IfModule>
