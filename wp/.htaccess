# ─── WordPress /wp/ subdirectory — internal mod_rewrite rules ─────────────────
# These rules live inside the /wp/ directory itself and tell WordPress how to
# route its own internal requests.  The domain-root .htaccess handles routing
# from the public URL space (e.g. /wp-admin/ → /wp/wp-admin/).
#
# This configuration supports:
#   1. WordPress permalink structures (custom, post name, date-based, etc.)
#   2. Standard WordPress subdirectory installation pattern
#   3. WooCommerce product/shop URLs
#
# RewriteBase must match the subdirectory WordPress is installed in (/wp/).

# ─── PHP upload limits (mod_php fallback) ────────────────────────────────────
# Supports schematics bulk import (ZIP + CSV) and WooCommerce product CSV import.
# On HostGator PHP-FPM/FastCGI these are ignored in favour of .user.ini — both
# files must be kept in sync.
<IfModule mod_php.c>
    php_value upload_max_filesize 128M
    php_value post_max_size       256M
    php_value memory_limit        256M
    php_value max_execution_time  300
    php_value max_input_time      300
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 128M
    php_value post_max_size       256M
    php_value memory_limit        256M
    php_value max_execution_time  300
    php_value max_input_time      300
</IfModule>

# BEGIN NFD EPC
<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresByType image/jpg "access plus 1 year"
	ExpiresByType image/jpeg "access plus 1 year"
	ExpiresByType image/gif "access plus 1 year"
	ExpiresByType image/png "access plus 1 year"
	ExpiresByType text/css "access plus 1 month"
	ExpiresByType application/pdf "access plus 1 month"
	ExpiresByType text/javascript "access plus 1 month"
	ExpiresByType text/html "access plus 2 hours"
	ExpiresByType image/x-icon "access plus 1 year"
	ExpiresDefault "access plus 6 hours"
</IfModule>
# END NFD EPC
# BEGIN WordPress
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /wp/

    # Pass the Authorization header through to PHP on CGI/FastCGI hosts
    # (HostGator shared hosting strips it by default).
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Don't rewrite index.php itself
    RewriteRule ^index\.php$ - [L]
    
    # Don't rewrite existing files
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rewrite all other requests to index.php (this enables custom permalink structures)
    RewriteRule . index.php [L]
</IfModule>
# END WordPress