# ─── WordPress Server Constants Template ─────────────────────────────────────
# All constants below map 1-to-1 to define() calls in wp/wp-config.php
# (Section 9 — DTB Application Constants, plus Sections 1, 2, 4).
#
# This file is committed as a reference template with placeholder values only.
# The real wp-config.php lives on the server and is covered by .gitignore.
#
# Companion file: frontend/.env.example — build-time variables for the React SPA.
# Note: the two files are intentionally different. The React bundle must never
# contain WC credentials; all authenticated WC calls go through the server-side
# proxy in wp-content/mu-plugins/dtb-rest-api.php.
#
# NEVER commit a populated secrets file.
# ──────────────────────────────────────────────────────────────────────────────


# ─── Environment Type ─────────────────────────────────────────────────────────
# Accepted values: production | staging | development
# Controls WP_DEBUG, SAVEQUERIES, and WP_DEBUG_LOG.
WP_ENVIRONMENT_TYPE=production


# ─── Database Credentials ─────────────────────────────────────────────────────
# Obtain from your hosting control panel (cPanel / WHM → MySQL® Databases).
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
# Optional: only set if you use a custom table prefix (default: wp_)
# DB_TABLE_PREFIX=wp_


# ─── WordPress Security Keys & Salts ──────────────────────────────────────────
# Generate a fresh set at: https://api.wordpress.org/secret-key/1.1/salt/
# Each value should be a unique, random string of 60+ characters.
WP_AUTH_KEY=put-your-unique-phrase-here
WP_SECURE_AUTH_KEY=put-your-unique-phrase-here
WP_LOGGED_IN_KEY=put-your-unique-phrase-here
WP_NONCE_KEY=put-your-unique-phrase-here
WP_AUTH_SALT=put-your-unique-phrase-here
WP_SECURE_AUTH_SALT=put-your-unique-phrase-here
WP_LOGGED_IN_SALT=put-your-unique-phrase-here
WP_NONCE_SALT=put-your-unique-phrase-here


# ─── WooCommerce REST API Proxy ───────────────────────────────────────────────
# Used by dtb-rest-api.php (mu-plugin) to make server-side authenticated calls
# to the WC REST API v3. These credentials NEVER reach the browser.
# Generate: WP Admin → WooCommerce → Settings → Advanced → REST API
#           → Add Key → Permissions: Read/Write → copy Key and Secret.
# wp-config.php: WC_PROXY_CONSUMER_KEY / WC_PROXY_CONSUMER_SECRET
WC_PROXY_CONSUMER_KEY=ck_your_consumer_key_here
WC_PROXY_CONSUMER_SECRET=cs_your_consumer_secret_here


# ─── WooCommerce Application Password (SPA runtime auth) ─────────────────────
# Returned to the React SPA at runtime via GET /wp-json/dtb/v1/config.
# Only returned to requests from an allowed CORS Origin.
# Generate: WP Admin → Users → (your user) → Application Passwords → Add New.
# wp-config.php: DTB_WC_AUTH_USER / DTB_WC_AUTH_PASS
DTB_WC_AUTH_USER=your_wp_username
DTB_WC_AUTH_PASS=xxxx xxxx xxxx xxxx xxxx xxxx


# ─── WooCommerce Webhook Secret ───────────────────────────────────────────────
# Shared secret used by dtb-rest-api.php to verify the X-WC-Webhook-Signature
# HMAC on every incoming webhook delivery.
# Must match the secret on each webhook in:
#   WP Admin → WooCommerce → Settings → Advanced → Webhooks.
# Generate: openssl rand -hex 32
# wp-config.php: WC_WEBHOOK_SECRET
WC_WEBHOOK_SECRET=your-64-char-hex-secret-here


# ─── JWT Authentication ───────────────────────────────────────────────────────
# Signs/verifies JWT tokens issued by the Simple JWT Login plugin.
# Must also be set in: WP Admin → Simple JWT Login → General → Secret Key.
# Generate: openssl rand -hex 32
# wp-config.php: DRYWALL_JWT_SECRET
DRYWALL_JWT_SECRET=your-64-char-hex-secret-here


# ─── Catalog Import ───────────────────────────────────────────────────────────
# Auth token for POST /wp-json/dtb/v1/import-catalog.
# Set the identical value in the CATALOG_IMPORT_SECRET GitHub Actions secret
# so the deploy workflow can trigger a WC product re-import.
# Generate: openssl rand -hex 32
# wp-config.php: DTB_IMPORT_SECRET
DTB_IMPORT_SECRET=your-64-char-hex-secret-here

# Optional: override the CSV filename used by /dtb/v1/products-csv and
# /dtb/v1/import-catalog. When omitted, dtb-utils.php auto-discovers the
# newest product-wc-*.csv file in wp-content/uploads/wc-imports/ via glob.
# Manage catalog CSV files via WooCommerce → Products → Import in WP Admin.
# wp-config.php: DTB_WC_CSV_FILENAME
# DTB_WC_CSV_FILENAME=

# Optional: staged rollout switch for dtb-catalog-platform bootstrap.
# Recommended false during import/backfill verification, then true once
# catalog API and product/card/cart smoke checks pass.
# wp-config.php: DTB_CATALOG_PLATFORM_ENABLED
# DTB_CATALOG_PLATFORM_ENABLED=false


# ─── Optional Overrides ───────────────────────────────────────────────────────
# Uncomment and set only if you need to override the defaults.

# Extra CORS origin (e.g. a staging domain). Hard-coded allowed origins are
# defined in 00-dtb-loader.php and do not need to be listed here.
# wp-config.php: DRYWALL_ALLOWED_ORIGIN
# DRYWALL_ALLOWED_ORIGIN=https://staging.drywalltoolbox.com

# Webhook delivery URL. Default is hardcoded in dtb-utils.php:
#   https://drywalltoolbox.com/wp-json/drywall/v1/webhooks/products
# Only set this to override (e.g. on a staging domain).
# wp-config.php: DTB_WEBHOOK_DELIVERY_URL
# DTB_WEBHOOK_DELIVERY_URL=https://drywalltoolbox.com/wp-json/drywall/v1/webhooks/products
