# ─── WordPress Server Environment Template ────────────────────────────────────
# This template lives at wp/.env.example in the repository.
# The REAL secrets file belongs ONE directory ABOVE the WordPress root, i.e.:
#
#   Repository path:  wp/.env.example          (this template — committed)
#   Server path:      /home/<user>/.env         (real secrets — NOT committed)
#
# Why above the web root?  The wp-config.php loader reads:
#   dirname(__DIR__) . '/.env'
# If WordPress is deployed to /home/<user>/public_html/, that resolves to
# /home/<user>/.env — a location inaccessible to web visitors.
#
# NEVER commit a populated .env file. This template (with placeholder values)
# is safe to commit; the real secrets file is covered by .gitignore.
#
# The wp-config.php .env loader will NOT override variables that are already
# present in the server environment (set by Apache/Nginx, WHM, or CI).
# ──────────────────────────────────────────────────────────────────────────────


# ─── Environment Type ─────────────────────────────────────────────────────────
# Accepted values: production | staging | development
# Controls WP_DEBUG, SAVEQUERIES, and WP_DEBUG_LOG.
WP_ENVIRONMENT_TYPE=production


# ─── Database Credentials ─────────────────────────────────────────────────────
# Obtain from your hosting control panel (cPanel / WHM → MySQL® Databases).
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
# Optional: only set if you use a custom table prefix (default: wp_)
# DB_TABLE_PREFIX=wp_


# ─── WordPress Security Keys & Salts ──────────────────────────────────────────
# Generate a fresh set at: https://api.wordpress.org/secret-key/1.1/salt/
# Each value should be a unique, random string of 60+ characters.
WP_AUTH_KEY=put-your-unique-phrase-here
WP_SECURE_AUTH_KEY=put-your-unique-phrase-here
WP_LOGGED_IN_KEY=put-your-unique-phrase-here
WP_NONCE_KEY=put-your-unique-phrase-here
WP_AUTH_SALT=put-your-unique-phrase-here
WP_SECURE_AUTH_SALT=put-your-unique-phrase-here
WP_LOGGED_IN_SALT=put-your-unique-phrase-here
WP_NONCE_SALT=put-your-unique-phrase-here


# ─── WooCommerce REST API Proxy ───────────────────────────────────────────────
# Used by drywall-api-proxy.php (mu-plugin) to make authenticated WC API calls.
# Obtain in WP Admin → WooCommerce → Settings → Advanced → REST API.
# Set Permissions to "Read/Write" and copy both keys.
WC_PROXY_CONSUMER_KEY=ck_your_consumer_key_here
WC_PROXY_CONSUMER_SECRET=cs_your_consumer_secret_here


# ─── WooCommerce Webhook Secret ───────────────────────────────────────────────
# Used by drywall-webhooks.php to verify incoming WC webhook HMAC signatures.
# Generate with: openssl rand -hex 32
# Must match the secret configured on each webhook in WP Admin → WooCommerce →
# Settings → Advanced → Webhooks.
WC_WEBHOOK_SECRET=your-random-high-entropy-string-here


# ─── JWT Authentication ───────────────────────────────────────────────────────
# Used by the active JWT plugin (e.g. simple-jwt-login) to sign/verify tokens.
# Generate with: openssl rand -hex 32
# Must match the secret set inside the JWT plugin's settings page.
DRYWALL_JWT_SECRET=your-jwt-signing-secret-here


# ─── CORS Allowed Origin ──────────────────────────────────────────────────────
# The primary domain where the compiled React SPA is served.
DRYWALL_ALLOWED_ORIGIN=https://drywalltoolbox.com


# ─── Catalog Import ───────────────────────────────────────────────────────────
# Secret token that authenticates POST /wp-json/dtb/v1/import-catalog.
# Generate with: openssl rand -hex 32
DTB_IMPORT_SECRET=your-random-import-secret-here

# Filename of the WooCommerce import CSV inside uploads/wc-imports/.
# The default value below is the canonical production filename used across all
# environments. Only override this if you intentionally rename or rotate the
# file (e.g. after a bulk-catalog rebuild).
DTB_WC_CSV_FILENAME=product-wp-catalog-c7p3my05pn.csv

# Application-password credentials used by the import endpoint.
# Create in WP Admin → Users → Edit user → Application Passwords.
DTB_WC_AUTH_USER=your_app_password_username
DTB_WC_AUTH_PASS=your_app_password_string
